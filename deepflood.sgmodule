
#!name=DeepFlood自动签到
#!desc=每日定时签到，模块参数可调整签到时间。\n打开DeepFlood网站「个人账号设置」页面即可获取token。
#!author=@Sliverkiss (Modified for DeepFlood)
#!update=2024-12-26
#!credit=基于@Sliverkiss NodeSeek原创脚本修改，由Claude优化模块可读性

#!arguments=定时签到:5 0 * * *,禁用脚本:DeepFlood[Token],禁用MITM:hostname
#!arguments-desc=定时签到：Cron表达式，默认每天 00:05 执行，可自定义修改\n\n禁用脚本：禁用获取Token功能，输入 # 表示禁用\n\n禁用MITM：禁用MITM主机名，输入 # 表示禁用\n\n脚本来源：请上传到您的个人Gist并替换URL

[Script]
# 定时签到任务
DeepFlood[签到] = type=cron,cronexp="{{{定时签到}}}",wake-system=1,timeout=180,script-path=https://gist.github.com/RerrentLinden/91c4db5f85955ed6043829d73fc69f42/raw/deepflood.js

# Token获取配置 (可通过参数禁用)
{{{禁用脚本}}} = type=http-response,pattern=^https:\/\/www\.deepflood\.com\/api\/account\/getInfo\/(.+)phone=1,script-path=https://gist.github.com/RerrentLinden/91c4db5f85955ed6043829d73fc69f42/raw/deepflood.js,requires-body=true,timeout=60

[MITM]
{{{禁用MITM}}} = %APPEND% www.deepflood.com
